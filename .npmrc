# セキュリティ設定

# 最高解像度モードを使用して、既知の脆弱性を含む古いバージョンの解決を防ぐ。
resolution-mode=highest

# サプライチェーン攻撃対策:
# 公開から72時間未満のパッケージバージョンのインストールを拒否する。
# 悪意あるパッケージは通常、公開直後に検知・削除されるため、
# この待機期間により typosquatting や account takeover 攻撃のリスクを軽減する。
# 緊急のセキュリティパッチ等で即時更新が必要な場合は一時的にコメントアウトすること。
min-released-date=3d

# Electron ビルド互換性:
# electron-builder は node_modules のフラットな構造を期待するが、
# pnpm の isolated モードではオプショナル依存パッケージ（プラットフォーム固有の
# ネイティブバインディング）が node_modules 直下に配置されない。
# これにより、パッケージング後に "Cannot find native binding" エラーが発生する。
# 該当パッケージを public-hoist-pattern でホイストすることで解決する。
public-hoist-pattern[]=@napi-rs/image-*
public-hoist-pattern[]=@resvg/resvg-js-*
public-hoist-pattern[]=sqlite3
public-hoist-pattern[]=clip-filepaths
