{
  "name": "vrchat-albums",
  "version": "0.28.0",
  "description": "VRChatで撮影した写真を整理・管理するためのデスクトップアプリケーションです。VRChatのログファイルと写真を自動的に関連付けて、いつ、どのワールドで撮影したかを簡単に確認できます。",
  "keywords": [
    "electrobun",
    "react",
    "typescript",
    "vite"
  ],
  "author": {
    "name": "tktcorporation"
  },
  "repository": {
    "url": "https://github.com/tktcorporation/vrchat-albums"
  },
  "type": "module",
  "scripts": {
    "postinstall": "simple-git-hooks && pnpm run license-check:generate",
    "setup:debug": "bash debug/genDevFiles.sh",
    "generate:debug-data": "tsx scripts/generate-debug-data.mts",
    "generate:icons": "tsx scripts/generate-platform-icons.ts",
    "dev": "electrobun dev",
    "dev:vite": "vite",
    "dev:landing": "pnpm --filter @vrchat-albums/landing-page dev",
    "build:landing": "pnpm --filter @vrchat-albums/landing-page build",
    "build": "run-s lint:type-check build:vite",
    "build:vite": "vite build",
    "build:electrobun": "electrobun build",
    "dist": "run-s clean:build build:vite build:electrobun",
    "clean:build": "rimraf dist build artifacts src/out",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "clean:debug": "bash debug/cleanDevFiles.sh",
    "find-deadcode": "knip --include unlisted",
    "license-check:generate": "node scripts/generate-licenses.mjs",
    "license-check:validate": "license-checker --production --failOn 'GPL;GPL-2.0;GPL-3.0;LGPL;LGPL-3.0;AGPL;AGPL-3.0;AGPL-3.0-only;'",
    "test": "vitest run",
    "test:web": "vitest run --project web",
    "test:electron": "vitest run --project electron",
    "test:playwright": "SENTRY_DSN='' run-s build \"playwright:setup-and-run\" sync-landing-images",
    "dev:trpc-server": "node --import ./scripts/mock-electrobun-loader.mjs --import tsx scripts/dev-trpc-server.ts",
    "playwright:setup-and-run": "playwright install --with-deps && playwright test --timeout=60000",
    "sync-landing-images": "bash scripts/sync-landing-images.sh",
    "lint": "run-p lint:oxlint lint:fmt-check lint:type-check lint:actionlint lint:valueobjects lint:effect lint:ast-grep lint:node-types lint:jsdoc-see lint:ts-pattern lint:logger-level lint:floating-promises",
    "lint:valueobjects": "tsx scripts/lint-valueobjects.ts",
    "lint:effect": "tsx scripts/lint-effect.ts",
    "lint:node-types": "tsx scripts/lint-node-types.ts",
    "lint:jsdoc-see": "tsx scripts/lint-jsdoc-see.ts",
    "lint:ts-pattern": "tsx scripts/lint-ts-pattern.ts",
    "lint:logger-level": "tsx scripts/lint-logger-level.ts",
    "lint:floating-promises": "tsx scripts/lint-floating-promises.ts",
    "lint:ast-grep": "ast-grep scan --warning",
    "lint:oxlint": "oxlint",
    "lint:fmt-check": "oxfmt --check .",
    "lint:type-check": "run-p lint:type-check:tsgo:electron lint:type-check:tsgo:src",
    "lint:type-check:tsc": "run-p lint:type-check:tsc:electron lint:type-check:tsc:src",
    "lint:type-check:tsc:electron": "tsc --noEmit -p electron",
    "lint:type-check:tsc:src": "tsc --noEmit",
    "lint:type-check:tsgo": "run-p lint:type-check:tsgo:electron lint:type-check:tsgo:src",
    "lint:type-check:tsgo:electron": "tsgo --noEmit -p electron",
    "lint:type-check:tsgo:src": "tsgo --noEmit",
    "lint:actionlint": "npx @tktco/node-actionlint",
    "lint:fix": "run-s lint:fix:fmt lint:fix:oxlint lint:type-check",
    "lint:fix:fmt": "oxfmt --write .",
    "lint:fix:oxlint": "oxlint --fix",
    "lint:fix:tsc": "run-s lint:fix:fmt lint:fix:oxlint lint:type-check:tsc",
    "sentry:sourcemaps": "run-s sentry:sourcemaps:electron sentry:sourcemaps:vite",
    "sentry:sourcemaps:electron": "sentry-cli sourcemaps inject ./main && sentry-cli sourcemaps upload ./main",
    "sentry:sourcemaps:vite": "sentry-cli sourcemaps inject ./src/out && sentry-cli sourcemaps upload ./src/out",
    "knip": "knip --config knip.config.ts"
  },
  "dependencies": {
    "@napi-rs/image": "^1.12.0",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-context-menu": "~2.2.16",
    "@radix-ui/react-dialog": "~1.1.15",
    "@radix-ui/react-label": "~2.1.8",
    "@radix-ui/react-scroll-area": "~1.2.10",
    "@radix-ui/react-slot": "~1.2.4",
    "@radix-ui/react-switch": "~1.2.6",
    "@radix-ui/react-toast": "~1.2.15",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/browser": "^10.47.0",
    "@sentry/cli": "~3.0.3",
    "@sentry/node": "^10.47.0",
    "@sentry/vite-plugin": "^4.7.0",
    "@sequelize/core": "7.0.0-alpha.47",
    "@sequelize/sqlite3": "7.0.0-alpha.47",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-virtual": "~3.13.18",
    "@trpc/client": "^11.8.1",
    "@trpc/react-query": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "@vitejs/plugin-react": "5.1.2",
    "class-variance-authority": "0.7.1",
    "clip-filepaths": "^0.3.0",
    "clsx": "2.1.1",
    "consola": "~3.4.2",
    "date-fns": "^4.1.0",
    "effect": "^3.21.0",
    "electrobun": "^1.12.3",
    "exiftool-vendored": "^34.3.0",
    "glob": "^13.0.0",
    "hash-wasm": "^4.12.0",
    "jotai": "~2.16.2",
    "lucide-react": "^0.562.0",
    "ofetch": "~1.5.1",
    "p-queue": "~9.0.1",
    "pathe": "2.0.3",
    "pony-cause": "2.1.11",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "^6.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "~7.8.2",
    "superjson": "2.2.6",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "^4.1.18",
    "ts-pattern": "5.9.0",
    "tw-animate-css": "^1.4.0",
    "ufo": "~1.6.3",
    "uuidv7": "~1.1.0",
    "vite": "^7.3.1",
    "zod": "~4.3.5",
    "zustand": "5.0.9"
  },
  "devDependencies": {
    "@antfu/ni": "^28.2.0",
    "@ast-grep/cli": "^0.42.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "1.57.0",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.2",
    "@tktco/node-actionlint": "~1.6.0",
    "@types/license-checker": "25.0.6",
    "@types/node": "~22.15.35",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "~7.0.0-dev.20260120.1",
    "@vitest/coverage-v8": "^4.0.17",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "autoprefixer": "10.4.23",
    "jsdom": "~27.4.0",
    "knip": "5.78.0",
    "license-checker": "25.0.1",
    "minimatch": "^10.2.3",
    "npm-run-all2": "~8.0.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "playwright": "1.57.0",
    "postcss": "8.5.6",
    "rimraf": "6.1.2",
    "simple-git-hooks": "2.13.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "uuid": "^13.0.0",
    "vitest": "^4.0.17"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint:oxlint && pnpm lint:fmt-check && pnpm lint:type-check",
    "prepare-commit-msg": "bash scripts/hooks/prepare-commit-msg.sh"
  },
  "engines": {
    "node": "22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "overrides": {
      "cacache>glob": "10.5.0",
      "@isaacs/brace-expansion": ">=5.0.1",
      "rollup": ">=4.59.0",
      "lodash": ">=4.18.0",
      "@xmldom/xmldom": ">=0.8.12",
      "dottie": ">=2.0.7",
      "undici": ">=6.24.0",
      "picomatch": ">=4.0.4",
      "flatted": ">=3.4.2",
      "smol-toml": ">=1.6.1"
    },
    "onlyBuiltDependencies": [
      "@ast-grep/cli",
      "@sentry/cli",
      "esbuild",
      "simple-git-hooks",
      "sqlite3"
    ]
  },
  "productName": "VRChatAlbums"
}
